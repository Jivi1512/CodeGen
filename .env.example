# Environment Variables Example
# Duplicate this file to .env and populate with your credentials

# Gemini API key (supports gemma-2-2b-it)
GEMINI_API_KEY=

# DeepSeek API keys (for deepseek-chat or deepseek-coder)
DEEPSEEK_API_KEY=

# Supabase database integration for safe storage of generated files
SUPABASE_URL=
SUPABASE_ANON_KEY=
